{
  "name": "saas-starter-kit",
  "version": "1.2.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "cross-env SKIP_DB_HEALTHCHECK=true SKIP_ENV_VALIDATION=true next build",
    "start": "next start",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "security:deps": "npm audit --audit-level high",
    "security:secrets": "gitleaks detect --source . --no-git 2>/dev/null || echo 'Gitleaks not installed'",
    "security:config": "npx create-qa-architect@latest --security-config",
    "security:all": "npm run security:deps && npm run security:secrets",
    "audit:types": "npm run type-check:all",
    "audit:lint": "npm run lint",
    "audit:format": "npm run format:check",
    "audit:styles": "stylelint \"src/**/*.{css,scss,sass,less,pcss}\" --allow-empty-input",
    "audit:schema": "npx prisma validate && npx prisma migrate status --skip-generate 2>/dev/null || true",
    "audit:tests": "npm run test",
    "audit:coverage": "npm run test:coverage",
    "audit:build": "npm run build",
    "audit:bundle": "npm run build:analyze 2>/dev/null || echo 'Bundle analysis requires ANALYZE=true'",
    "audit:deps": "npm run security:deps && npm outdated || true",
    "audit:secrets": "npm run security:secrets && npm run test:secrets",
    "audit:licenses": "npx license-checker --summary --onlyAllow 'MIT;Apache-2.0;BSD-2-Clause;BSD-3-Clause;ISC;0BSD;CC0-1.0;Unlicense' 2>/dev/null || echo 'license-checker not installed'",
    "audit:docs": "npm run validate:docs 2>/dev/null || true",
    "audit:e2e": "npm run test:e2e",
    "audit:perf": "npm run lighthouse:ci 2>/dev/null || echo 'Lighthouse CI not configured'",
    "audit:quick": "npm run audit:types && npm run audit:lint && npm run audit:format && npm run audit:tests",
    "audit:full": "npm run audit:types && npm run audit:lint && npm run audit:format && npm run audit:styles && npm run audit:schema && npm run audit:tests && npm run audit:coverage && npm run audit:build && npm run audit:deps && npm run audit:secrets && npm run audit:licenses && npm run audit:docs",
    "audit:release": "npm run audit:full && npm run audit:e2e && npm run audit:perf",
    "lint:fix": "eslint . --fix && stylelint \"src/**/*.{css,scss,sass,less,pcss}\" --fix --allow-empty-input",
    "prepare": "husky",
    "analyze": "ANALYZE=true npm run build",
    "build:analyze": "cross-env ANALYZE=true next build",
    "export": "next export",
    "validate:all": "npm run lint && npm run typecheck && npm run security:deps",
    "validate:docs": "npx create-qa-architect@latest --validate-docs",
    "validate:comprehensive": "npx create-qa-architect@latest --comprehensive",
    "template:package": "tsx scripts/package-template.ts",
    "validate:pre-push": "npm run test:patterns --if-present && npm run lint && npm run format:check && npm run test:commands --if-present && npm test --if-present",
    "lighthouse:ci": "lhci autorun",
    "lighthouse:upload": "lhci upload",
    "type-check": "tsc --noEmit",
    "type-check:tests": "tsc --noEmit --project tests/tsconfig.json",
    "type-check:all": "npm run type-check && npm run type-check:tests",
    "quality:check": "npm run type-check:all && npm run lint && npm run test",
    "quality:ci": "npm run quality:check && npm run security:deps",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:secrets": "trufflehog filesystem . --only-verified --fail 2>/dev/null || echo 'TruffleHog not installed - run: brew install trufflehog'"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@octokit/rest": "^20.1.2",
    "@prisma/client": "7.2.0",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@sentry/nextjs": "^10.27.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.86.2",
    "@testing-library/dom": "^10.4.1",
    "@types/archiver": "^7.0.0",
    "archiver": "^7.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.548.0",
    "next": "^16.1.6",
    "next-auth": "^4.24.13",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.2",
    "prom-client": "^15.1.3",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "stripe": "^16.12.0",
    "tailwind-merge": "^3.3.1",
    "tw-animate-css": "^1.2.9",
    "zod": "^4.1.12",
    "zustand": "^4.0.0"
  },
  "devDependencies": {
    "@jest/types": "^29.0.0",
    "@playwright/test": "^1.56.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.0.0",
    "@types/jest": "^29.0.0",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^8.48.1",
    "@typescript-eslint/parser": "^8.48.1",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.0.14",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-jest": "^29.15.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-security": "^3.0.1",
    "globals": "^15.9.0",
    "husky": "^9.1.4",
    "jest": "^29.0.0",
    "jest-axe": "^9.0.0",
    "jest-environment-jsdom": "^29.0.0",
    "lint-staged": "^15.2.10",
    "next-router-mock": "^0.9.0",
    "postcss": "^8.4.0",
    "prettier": "^3.0.0",
    "prisma": "7.2.0",
    "stylelint": "^16.8.0",
    "stylelint-config-standard": "^37.0.0",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "^5.0.0",
    "vitest": "^4.0.14",
    "vitest-axe": "^0.1.0",
    "webpack-bundle-analyzer": "^4.10.2"
  },
  "overrides": {
    "glob": "^11.0.0",
    "@hono/node-server": "^1.19.10",
    "hono": "^4.12.4"
  },
  "lint-staged": {
    "package.json": [
      "prettier --write"
    ],
    "**/*.{js,jsx,ts,tsx,mjs,cjs,html}": [
      "eslint --fix",
      "prettier --write"
    ],
    "**/*.{json,md,yml,yaml}": [
      "prettier --write"
    ],
    "src/**/*.{css,scss,sass,less,pcss}": [
      "stylelint --fix",
      "prettier --write"
    ],
    "**/*.{js,jsx,mjs,cjs,html}": [
      "eslint --fix",
      "prettier --write"
    ],
    "**/*.{css,scss,sass,less,pcss}": [
      "stylelint --fix",
      "prettier --write"
    ],
    "**/*.{ts,tsx}": [
      "bash -c 'tsc --noEmit --skipLibCheck'",
      "eslint --fix",
      "prettier --write"
    ],
    "tests/**/*.{ts,tsx,js,jsx}": [
      "bash -c 'tsc --noEmit --project tests/tsconfig.json'",
      "eslint --fix",
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20"
  },
  "volta": {
    "node": "20.11.1",
    "npm": "10.2.4"
  }
}
