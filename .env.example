# Database (required)
DATABASE_URL="postgresql://user:password@localhost:5432/saas-db"

# =============================================================================
# Supabase Auth (REQUIRED)
# =============================================================================
# Get these from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# OAuth providers are configured in Supabase Dashboard:
# https://supabase.com/dashboard/project/_/auth/providers
# Supported: Google, GitHub, and email/password

# Sentry (Error Monitoring) - optional but recommended in prod
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""

# App Configuration
NEXT_PUBLIC_APP_VERSION="1.2.0"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Stripe (for payments) - required if billing is enabled
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# SaaS Product Pricing (for your customers)
STRIPE_PRICE_STARTER_MONTHLY="price_..."
STRIPE_PRICE_STARTER_YEARLY="price_..."
STRIPE_PRICE_PRO_MONTHLY="price_..."
STRIPE_PRICE_PRO_YEARLY="price_..."
STRIPE_PRICE_ENTERPRISE_MONTHLY="price_..."
STRIPE_PRICE_ENTERPRISE_YEARLY="price_..."

# Template Sales Pricing (selling the template itself)
STRIPE_TEMPLATE_BASIC_PRICE_ID="price_..."
STRIPE_TEMPLATE_PRO_PRICE_ID="price_..."
STRIPE_TEMPLATE_ENTERPRISE_PRICE_ID="price_..."

# Email (SendGrid)
SENDGRID_API_KEY=""
FROM_EMAIL="noreply@yourapp.com"
RESEND_API_KEY=""

# AWS (optional, for file uploads)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
AWS_S3_BUCKET=""

# =============================================================================
# Rate Limiting (REQUIRED in production)
# =============================================================================
# Get free Redis at: https://upstash.com
# In production: missing vars will throw an error (fail-fast for security)
# In dev/test: falls back to in-memory (warning logged)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# HMAC secret for spoof-resistant client identification
# Generate with: openssl rand -hex 32
# Required in production for secure IP+UA fingerprinting
RATE_LIMIT_HMAC_SECRET=""

# GitHub (for template access management when selling)
GITHUB_ACCESS_TOKEN=""
GITHUB_ORG="your-github-org"

# Template Configuration (required for selling the template)
TEMPLATE_VERSION="1.0.0"
TEMPLATE_FULFILLMENT_SECRET="set-a-long-random-string"
TEMPLATE_FILES_PATH="./template-files"

# Vercel
VERCEL_TOKEN=""
VERCEL_ORG_ID=""
VERCEL_PROJECT_ID=""
